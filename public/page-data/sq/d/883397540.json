3ce8563eddcf51f9ae5159e9eb71b42/5f169/Nicolas_Bosnjak.webp 500w,\n/static/43ce8563eddcf51f9ae5159e9eb71b42/3cd29/Nicolas_Bosnjak.webp 1000w,\n/static/43ce8563eddcf51f9ae5159e9eb71b42/62c39/Nicolas_Bosnjak.webp 2000w","type":"image/webp","sizes":"(min-width: 1000px) 1000px, 100vw"}]},"width":1000,"height":1000}}},"description":{"fi":"Organisoi ISOhenkilöiden rekryämisen, koulutuksen ja yleisen toiminnan. Työskentelee yhteistyössä fuksikapteenien kanssa.","en":"The ISOboss is responsible of recruitment, preparation and general operation of tutors. They collaborate closely with the Fuksi Captains. Contact the ISOboss if your matter concerns tutors."}}},{"node":{"title":{"fi":"Isäntä","en":"Host"},"name":"Venla Mäkelä","email":"ie@as.fi","phone":null,"telegram":"venlamakela","picture":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/c03052fa4bc135b918b7eb0a4f8a8c96/5a7c3/Venla_Makela.jpg","srcSet":"/static/c03052fa4bc135b918b7eb0a4f8a8c96/f505e/Venla_Makela.jpg 250w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/be5ed/Venla_Makela.jpg 500w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/5a7c3/Venla_Makela.jpg 1000w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/5c8f1/Venla_Makela.jpg 2000w","sizes":"(min-width: 1000px) 1000px, 100vw"},"sources":[{"srcSet":"/static/c03052fa4bc135b918b7eb0a4f8a8c96/e7160/Venla_Makela.webp 250w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/5f169/Venla_Makela.webp 500w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/3cd29/Venla_Makela.webp 1000w,\n/static/c03052fa4bc135b918b7eb0a4f8a8c96/62c39/Venla_Makela.webp 2000w","type":"image/webp","sizes":"(min-width: 1000px) 1000px, 100vw"}]},"width":1000,"height":1000}}},"description":{"fi":"Järjestää yhdessä Emännän kanssa kiltalaisille mitä moninaisimpia tapahtumia ja huolehtii elintarvikkeiden välittämisestä killistien vatsalaukkuihin. Organisoi huvitoimikunnan toimintaa ja kehittää killan tapahtumakulttuuria.\nOta yhteyttä IE:hen, jos asiasi koskee killan tapahtumia.","en":"The Host arranges various events together with the hostess for the guild members. Together with Hostess they lead the Entertainment Committee and work towards even better events. Contact the Host or the Hostess if your matter concerns a guild event."}}},{"node":{"title":{"fi":"Emäntä","en":"Hostess"},"name":"Vilja Lohi","email":"ie@as.fi","phone":null,"telegram":"lohiviljelma","picture":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/335654c0554e44171af2a7c41632d2d8/5a7c3/Vilja_Lohi.jpg","srcSet":"/static/335654c0554e44171af2a7c41632d2d8/f505e/Vilja_Lohi.jpg 250w,\n/static/335654c0554e44171af2a7c41632d2d8/be5ed/Vilja_Lohi.jpg 500w,\n/static/335654c0554e44171af2a7c41632d2d8/5a7c3/Vilja_Lohi.jpg 1000w,\n/static/335654c0554e44171af2a7c41632d2d8/5c8f1/Vilja_Lohi.jpg 2000w","sizes":"(min-width: 1000px) 1000px, 100vw"},"sources":[{"srcSet":"/static/335654c0554e44171af2a7c41632d2d8/e7160/Vilja_Lohi.webp 250w,\n/static/335654c0554e44171af2a7c41632d2d8/5f169/Vilja_Lohi.webp 500w,\n/static/335654c0554e44171af2a7c41632d2d8/3cd29/Vilja_Lohi.webp 1000w,\n/static/335654c0554e44171af2a7c41632d2d8/62c39/Vilja_Lohi.webp 2000w","type":"image/webp","sizes":"(min-width: 1000px) 1000px, 100vw"}]},"width":1000,"height":1000}}},"description":{"fi":"Järjestää yhdessä Isännän kanssa kiltalaisille mitä moninaisimpia tapahtumia ja huolehtii elintarvikkeiden välittämisestä killistien vatsalaukkuihin. Organisoi huvitoimikunnan toimintaa ja kehittää killan tapahtumakulttuuria.\nOta yhteyttä IE:hen, jos asiasi koskee killan tapahtumia.","en":"The Hostess arranges various events together with the host for the guild members. Together with Host they lead the Entertainment Committee and work towards even better events. Contact the Hostess or the Host if your matter concerns a guild event."}}},{"node":{"title":{"fi":"Opintomestari","en":"Master of Studies"},"name":"Anastasia Parfenova","email":"opintomestari@as.fi","phone":null,"telegram":"ansqu3","picture":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/3bd994e33e0cbd432380d59312398563/5a7c3/Anastasia_Parfenova.jpg","srcSet":"/static/3bd994e33e0cbd432380d59312398563/f505e/Anastasia_Parfenova.jpg 250w,\n/static/3bd994e33e0cbd432380d59312398563/be5ed/Anastasia_Parfenova.jpg 500w,\n/static/3bd994e33e0cbd432380d59312398563/5a7c3/Anastasia_Parfenova.jpg 1000w,\n/static/3bd994e33e0cbd432380d59312398563/5c8f1/Anastasia_Parfenova.jpg 2000w","sizes":"(min-width: 1000px) 1000px, 100vw"},"sources":[{"srcSet":"/static/3bd994e33e0cbd432380d59312398563/e7160/Anastasia_Parfenova.webp 250w,\n/static/3bd994e33e0cbd432380d59312398563/5f169/Anastasia_Parfenova.webp 500w,\n/static/3bd994e33e0cbd432380d59312398563/3cd29/Anastasia_Parfenova.webp 1000w,\n/static/3bd994e33e0cbd432380d59312398563/62c39/Anastasia_Parfenova.webp 2000w","type":"image/webp","sizes":"(min-width: 1000px) 1000px, 100vw"}]},"width":1000,"height":1000}}},"description":{"fi":"Ylläpitää yhteyttä koulun henkilökuntaan, pitää itsensä tietoisena tutkinto-ohjelmassa tapahtuvista muutoksista ja vastaa kiltalaisten edunvalvonnasta. Johtaa killan opintotoimikuntaa.\nOpintomestariin voi ottaa yhteyttä opintoihin liittyvissä asioissa.","en":"The Master of Studies maintains communications between the guild and the university. They also work as the contact person for the guild's trustees and represent students in the meetings of the university's governing body. Contact the Master of Studies if your matter has to do with your studies or school in general."}}},{"node":{"title":{"fi":"Kulttuurimestari","en":"Master of Culture"},"name":"Lauri Tuominen","email":"kulttuurimestari@as.fi","phone":"+358 447455535","telegram":"retkimestari","picture":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/41cbff86ca23330156c017417616c320/5a7c3/Lauri_Tuominen.jpg","srcSet":"/static/41cbff86ca23330156c017417616c320/f505e/Lauri_Tuominen.jpg 250w,\n/static/41cbff86ca23330156c017417616c320/be5ed/Lauri_Tuominen.jpg 500w,\n/static/41cbff86ca23330156c017417616c320/5a7c3/Lauri_Tuominen.jpg 1000w,\n/static/41cbff86ca23330156c017417616c320/5c8f1/Lauri_Tuominen.jpg 2000w","sizes":"(min-width: 1000px) 1000px, 100vw"},"sources":[{"srcSet":"/static/41cbff86ca23330156c017417616c320/e7160/Lauri_Tuominen.webp 250w,\n/static/41cbff86ca23330156c017417616c320/5f169/Lauri_Tuominen.webp 500w,\n/static/41cbff86ca23330156c017417616c320/3cd29/Lauri_Tuominen.webp 1000w,\n/static/41cbff86ca23330156c017417616c320/62c39/Lauri_Tuominen.webp 2000w","type":"image/webp","sizes":"(min-width: 1000px) 1000px, 100vw"}]},"width":1000,"height":1000}}},"description":{"fi":"Pitää yllä killan vanhoja ulkosuhteita sekä luo uusia. Johtaa kulttuuritoimikuntaa ja järjestää sen jäsenten kanssa killale kulttuuritapahtumia. Tykkää pitää yhteyttä moneen eri tahoon ja hengailla myös muun kuin violetin väristen ihmisten kanssa. Ota yhteyttä kulttuurimestariin, jos asiasi liittyy kulttuuriasioihin.","en":"The Master of Culture maintains the external relations with student organisations across Finland and builds new ones. They lead the Culture and Sports Committee, organise various happenings, cultural excursions and events to test different sports. Contact the Master of Culture if your matter concerns culture in any way."}}}]}}}