---
import BaseLayout from '@layouts/BaseLayout.astro';
import Minors from '@components/minors/Minors';
import { getCollection } from 'astro:content';

const minorsEntries = await getCollection('minors');
const minorsData = minorsEntries.map(entry => entry.data);

const description = 'Täältä löydät tietoa sivuaineista, joita AS-kilta suosittelee.';
const lang = 'fi';
const slug = '/studies/minor-guide';
---

<BaseLayout
  title="Sivuaineopas"
  lead="Täältä löydät tietoa sivuaineista, joita AS-kilta suosittelee."
  description={description}
  lang={lang}
  slug={slug}
>
  <Minors data={minorsData} lang={lang} />
</BaseLayout>
