---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import timetable from '@src/assets/images/orientaatioviikon-aikataulu-2025.png';

const description = 'Orientaatioviikon aikataulu fukseille';
---

<BaseLayout title="Orientaatioviikko" description={description} lang="fi" slug="fuksis/orientationweek">
  <h2 id="Orientaatioviikon aikataulu"></h2>

  <div class="image-container">
    <p>Orientaatioviikko on hektistä aikaa, tekemistä on paljon!</p>
    <p>Tässä orientaatioviikon aikataulu, päivittelemme tätä parhaamme mukaan kesän aikana.</p>
    <Image class="centered-image" src={timetable} alt="timetable" />
  </div>
</BaseLayout>

<style>
  .centered-image {
    display: block;
    margin-left: auto;
    margin-right: auto;
    max-width: 100%;
    height: auto;
  }
</style>
