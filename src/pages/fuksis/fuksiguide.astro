---
import BaseLayout from '@layouts/BaseLayout.astro';

const description = 'Fuksiopas sisältää kaiken, mitä sinun tarvitsee tietää tulevasta opiskelijaelämästä ja AS-killasta.';
const lead = 'Fuksiopas sisältää kaiken, mitä sinun tarvitsee tietää tulevasta opiskelijaelämästä ja AS-killasta.';
---

<BaseLayout title="Fuksiopas 2025" lead={lead} description={description} lang="fi" slug="fuksis/fuksiguide">
  <div style={{ width: '100%' }}>
    <a
      style={{ marginBlock: '1rem' }}
      class="rounded-button"
      target="_blank"
      href="https://drive.google.com/file/d/1_BKL9n96N7v1mLIpDT6DHKHW7KqME5uo"
      rel="noreferrer"
    >
      Lataa PDF
    </a>
    <iframe
      src="https://drive.google.com/file/d/1_BKL9n96N7v1mLIpDT6DHKHW7KqME5uo/preview"
      width="100%"
      height="800"
      allow="autoplay"
    ></iframe>
  </div>
</BaseLayout>
