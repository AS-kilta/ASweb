---
import EventList from '@components/events/EventList';
---

<h1>Upcoming Events</h1>

<div class="content">
  <EventList number={5} lang="fi" client:load />
</div>

<link href="https://fonts.googleapis.com/css2?family=Jacquard+12&family=Space+Mono&display=swap" rel="stylesheet" />

<style is:global>
  h1 {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-style: normal;
    text-align: center;
    font-size: 100px;
    margin: 25px;
  }

  .content {
    height: 90%;
    width: 95%;
    margin: auto;
    font-family: 'Space Mono', monospace;
  }

  .content .event_list .eventListItem {
    display: flex !important;
    flex-direction: row !important;
    align-items: flex-start !important;
    gap: 30px !important;
    margin-bottom: 40px !important;
    font-size: 50px !important;
  }

  .content .event_list p {
    margin: 0 !important;
    line-height: 1.4 !important;
    font-size: 40px !important;
  }

  .content .event_list time {
    margin: 0 !important;
    line-height: 1.4 !important;
    font-size: 35px !important;
  }

  .content .event_list .summary {
    font-weight: bold !important;
    line-height: 1.1 !important;
    margin-bottom: 0.2em !important;
  }

  .content .event_list .date {
    aspect-ratio: 1 !important;
    flex-shrink: 0 !important;
    width: 175px !important;
    height: 175px !important;
    padding: 10px !important;
    border-radius: 5px !important;
    font-size: 50px !important;
  }
</style>
